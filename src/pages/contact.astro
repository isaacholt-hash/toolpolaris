---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact ToolPolaris — Tool Requests, Corrections & Feedback"
  description="Request a tool review, suggest a missing category, flag an error, or ask a question. We read every submission."
>
  <div class="page-hero">
    <div class="container">
      <p class="section-label">Contact</p>
      <h1>Get in touch</h1>
      <p class="page-sub">We read every submission. Typical response time: 2&ndash;3 business days.</p>
      <a href="#contact-form" class="btn-primary page-hero-cta">Request a Tool Review &rarr;</a>
    </div>
  </div>

  <section class="section">
    <div class="container contact-layout">

      <div class="contact-main">
        <form id="contact-form" class="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden"><label>Don&rsquo;t fill this out: <input name="bot-field" /></label></p>

          <div class="form-group">
            <label class="field-label" for="name">Your name</label>
            <input class="field-control" type="text" id="name" name="name" required placeholder="Jane Smith" />
          </div>

          <div class="form-group">
            <label class="field-label" for="email">Email address</label>
            <input class="field-control" type="email" id="email" name="email" required placeholder="jane@company.com" />
          </div>

          <div class="form-group">
            <label class="field-label" for="reason">What&rsquo;s this about?</label>
            <select class="field-control" id="reason" name="reason" required>
              <option value="" disabled selected>Select a reason</option>
              <option value="tool-request">Request a tool review</option>
              <option value="category-suggestion">Suggest a missing category</option>
              <option value="correction">Flag an error or outdated info</option>
              <option value="partnership">Partnership / sponsorship enquiry</option>
              <option value="other">Something else</option>
            </select>
          </div>

          <div class="form-group">
            <label class="field-label" for="message">Message</label>
            <textarea class="field-control" id="message" name="message" required rows="5" placeholder="Tell us which tool you&rsquo;d like reviewed, or describe your question..."></textarea>
          </div>

          <button type="submit" class="btn-submit">Submit Tool Review Request &rarr;</button>
        </form>
      </div>

      <aside class="contact-aside">
        <div class="aside-block">
          <h3>🔧 Tool review requests</h3>
          <p>Tell us the tool name, the use case you&rsquo;re evaluating it for, and anything specific you&rsquo;d like us to assess. We aim to publish within two weeks.</p>
        </div>
        <div class="aside-block">
          <h3>🚩 Corrections</h3>
          <p>Spotted outdated pricing, a changed feature, or an inaccurate claim? We&rsquo;ll update within 48 hours of a confirmed correction.</p>
        </div>
        <div class="aside-block">
          <h3>🤝 Partnerships</h3>
          <p>Sponsorship and featured placement enquiries are considered once we reach 20,000 monthly visitors. We&rsquo;ll keep your message on file.</p>
        </div>
      </aside>

    </div>
  </section>
</BaseLayout>

<style>
  .page-hero-cta { margin-top: 24px; }

  .contact-layout { display: grid; grid-template-columns: 1fr 320px; gap: 60px; }
  @media (max-width: 800px) { .contact-layout { grid-template-columns: 1fr; } }

  /* FORM */
  .contact-form { display: flex; flex-direction: column; gap: 20px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-group textarea { resize: vertical; min-height: 120px; }
  .btn-submit { background: var(--brand-accent); color: var(--brand-dark); font-weight: 700; font-size: 1rem; padding: 13px 28px; border-radius: var(--radius); border: none; cursor: pointer; transition: opacity .2s; align-self: flex-start; }
  .btn-submit:hover { opacity: .88; }
  .hidden { display: none; }

  /* ASIDE */
  .aside-block { background: var(--brand-light); border: 1px solid var(--color-gray-200); border-radius: var(--radius); padding: 20px; margin-bottom: 16px; }
  .aside-block h3 { font-size: 0.95rem; font-weight: 700; color: var(--brand-dark); margin-bottom: 8px; }
  .aside-block p  { font-size: 0.85rem; color: var(--text-muted); line-height: 1.6; }
</style>
