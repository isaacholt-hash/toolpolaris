---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  { emoji: '✍️', name: 'AI Writing', slug: 'ai-writing-tools-marketers', desc: 'Long-form content, blog posts, email copy, product descriptions.' },
  { emoji: '📱', name: 'Social Media', slug: 'ai-social-media-marketing-tools', desc: 'Caption generation, scheduling, hashtag research, repurposing.' },
  { emoji: '🔎', name: 'SEO & Content', slug: 'ai-seo-tools-marketers', desc: 'Keyword research, content briefs, on-page optimization.' },
  { emoji: '📣', name: 'Ad Copy', slug: 'ai-ad-copy-tools', desc: 'Google Ads, Meta Ads, landing page copy, A/B variants.' },
  { emoji: '🧠', name: 'Market Research', slug: 'ai-tools-for-market-research', desc: 'Competitor intelligence, audience insights, trend analysis.' },
  { emoji: '⚡', name: 'Automation', slug: 'ai-automation-tools-marketers', desc: 'Workflow automation, multi-channel orchestration, AI agents.' },
];
---

<BaseLayout
  title="Browse AI Tools by Marketing Use Case | ToolPolaris"
  description="Find the best AI tools for your specific marketing role. Browse by use case - writing, SEO, social media, ad copy, analytics, email, design, and more."
>
  <div class="page-hero">
    <div class="container">
      <p class="section-label">Browse by Use Case</p>
      <h1>Find the right AI tools for <em>your</em> workflow</h1>
      <p class="page-sub">Not your colleague's workflow. Not a generic best AI tools list. Pick a use case and get rankings built around how you actually work.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="cat-grid">
        {categories.map((cat) => (
          <a href={`/tools/${cat.slug}/`} class="cat-card surface-card">
            <div class="cat-emoji">{cat.emoji}</div>
            <div class="cat-body">
              <h2>{cat.name}</h2>
              <p>{cat.desc}</p>
            </div>
            <div class="cat-arrow">&rarr;</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Not sure where to start?</h2>
      <p>Browse all tool reviews or tell us your role and we will point you in the right direction.</p>
      <div class="cta-actions">
        <a href="/tools/" class="btn-primary">All Tool Reviews &rarr;</a>
        <a href="/contact/" class="btn-secondary">Ask Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 18px;
  }

  .cat-card {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 22px;
    text-decoration: none;
    color: var(--text-primary);
  }

  .cat-emoji {
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    border-radius: var(--radius);
    background: rgba(245, 166, 35, 0.12);
    display: grid;
    place-items: center;
    font-size: 1.45rem;
  }

  .cat-body {
    flex: 1;
  }

  .cat-body h2 {
    font-size: 1rem;
    font-weight: 800;
    color: var(--brand-dark);
    margin-bottom: 6px;
  }

  .cat-body p {
    font-size: 0.84rem;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .cat-arrow {
    font-size: 1.15rem;
    color: var(--brand-accent);
    font-weight: 700;
    flex-shrink: 0;
  }

  .cta-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
