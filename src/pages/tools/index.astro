---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const sorted = articles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const categories = Array.from(
  sorted.reduce((map, article) => {
    const category = article.data.category;
    const group = map.get(category) ?? [];
    group.push(article);
    map.set(category, group);
    return map;
  }, new Map<string, typeof sorted>())
).sort(([a], [b]) => a.localeCompare(b));

const categoryId = (category: string) => `category-${category.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
---

<BaseLayout
  title="All AI Tool Reviews | ToolPolaris"
  description="Browse every AI tool review and comparison on ToolPolaris - ranked and filtered for marketing professionals."
>
  <div class="page-hero">
    <div class="container">
      <p class="section-label">All Tools</p>
      <h1>Every AI tool review, in one place</h1>
      <p class="page-sub">Browse by category below, or scroll through all reviews, comparisons, prompts, and buying guides.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      {sorted.length === 0 ? (
        <div class="empty-state">
          <p>Reviews are coming soon. Check back shortly.</p>
          <a href="/categories/" class="btn-primary" style="margin-top:20px;display:inline-flex;">Browse by Category &rarr;</a>
        </div>
      ) : (
        <>
          <div class="category-sections">
            {categories.map(([category, categoryArticles]) => (
              <section class="category-group" aria-labelledby={categoryId(category)}>
                <div class="category-group-head">
                  <h2 id={categoryId(category)}>{category}</h2>
                  <span>{categoryArticles.length} guides</span>
                </div>
                <div class="compact-grid">
                  {categoryArticles.slice(0, 4).map(article => (
                    <a href={`/tools/${article.slug}/`} class="compact-card">
                      <span>{article.data.title}</span>
                    </a>
                  ))}
                </div>
              </section>
            ))}
          </div>

          <div class="all-articles-head">
            <h2>All Guides</h2>
            <p>{sorted.length} total pages</p>
          </div>
          <div class="articles-grid">
            {sorted.map(article => (
              <a href={`/tools/${article.slug}/`} class="article-card">
                <span class="article-category">{article.data.category}</span>
                <h2>{article.data.title}</h2>
                <p>{article.data.description}</p>
                <span class="article-meta">{article.data.readTime ?? 8} min read &middot; {article.data.pubDate.toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' })}</span>
              </a>
            ))}
          </div>
        </>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { background: var(--brand-dark); padding: 64px 0 52px; }
  .page-hero h1 { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; color: #fff; margin: 10px 0 10px; letter-spacing: -0.3px; }
  .page-sub { font-size: 0.95rem; color: rgba(255,255,255,0.55); }

  .empty-state { text-align: center; padding: 60px 0; color: var(--text-muted); font-size: 1.1rem; }

  .category-sections { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 22px; margin-bottom: 52px; }
  .category-group { border: 1.5px solid #e4e9f0; border-radius: var(--radius); padding: 20px; background: #fff; }
  .category-group-head { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; margin-bottom: 14px; }
  .category-group-head h2 { font-size: 1rem; font-weight: 800; color: var(--brand-dark); }
  .category-group-head span { font-size: 0.76rem; font-weight: 700; color: var(--text-muted); white-space: nowrap; }
  .compact-grid { display: flex; flex-direction: column; gap: 8px; }
  .compact-card { display: block; padding: 10px 12px; border-radius: 6px; background: var(--brand-light); color: var(--brand-dark); text-decoration: none; font-size: 0.84rem; font-weight: 700; line-height: 1.4; }
  .compact-card:hover { color: var(--brand-accent); }
  .all-articles-head { display: flex; justify-content: space-between; align-items: end; gap: 20px; margin-bottom: 18px; }
  .all-articles-head h2 { font-size: 1.25rem; font-weight: 800; color: var(--brand-dark); }
  .all-articles-head p { font-size: 0.86rem; color: var(--text-muted); }

  .articles-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
  .article-card { display: flex; flex-direction: column; gap: 8px; background: #fff; border: 1.5px solid #e4e9f0; border-radius: var(--radius); padding: 24px; text-decoration: none; color: var(--text-primary); transition: border-color .2s, box-shadow .15s; }
  .article-card:hover { border-color: var(--brand-accent); box-shadow: 0 4px 18px rgba(15,31,61,0.08); }
  .article-category { font-size: 0.7rem; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--brand-accent); }
  .article-card h2 { font-size: 1rem; font-weight: 700; line-height: 1.35; }
  .article-card p { font-size: 0.85rem; color: var(--text-muted); line-height: 1.55; flex: 1; }
  .article-meta { font-size: 0.75rem; color: #aab; font-weight: 500; }

  @media (max-width: 640px) {
    .all-articles-head { align-items: flex-start; flex-direction: column; gap: 4px; }
  }
</style>
