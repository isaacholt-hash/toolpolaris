---
// StackAuditCTA.astro — sidebar card promoting the Polaris Stack Audit
// Drop into any sidebar; links to /stack-audit/ landing page
---

<div class="audit-cta-card">
  <p class="audit-cta-title">Paying for tools you barely use?</p>
  <p class="audit-cta-desc">
    We'll audit your AI stack, tell you exactly what to cut and what to add, and deliver a personalised Loom walkthrough + one-page PDF in 48 hours.
  </p>
  <p class="audit-cta-price">$197 &mdash; one payment, no Zoom calls.</p>
  <a href="/stack-audit/" class="audit-cta-btn">&rarr; Get My Stack Audit</a>
  <p class="audit-cta-guarantee">30-day money-back guarantee.</p>
</div>

<style>
  .audit-cta-card {
    background: #fff;
    border: 2px solid #0f1f3d;
    border-radius: 10px;
    padding: 24px;
    margin-bottom: 20px;
  }

  .audit-cta-title {
    font-size: 1rem;
    font-weight: 800;
    color: #0f1f3d;
    line-height: 1.35;
    margin: 0 0 12px;
  }

  .audit-cta-desc {
    font-size: 0.82rem;
    color: #4a5568;
    line-height: 1.6;
    margin: 0 0 12px;
  }

  .audit-cta-price {
    font-size: 0.88rem;
    font-weight: 700;
    color: #0f1f3d;
    margin: 0 0 16px;
  }

  .audit-cta-btn {
    display: block;
    text-align: center;
    background: #f5a623;
    color: #0f1f3d;
    font-weight: 800;
    font-size: 0.88rem;
    padding: 11px 16px;
    border-radius: 6px;
    text-decoration: none;
    transition: opacity 0.2s;
    margin-bottom: 10px;
  }

  .audit-cta-btn:hover {
    opacity: 0.88;
  }

  .audit-cta-guarantee {
    font-size: 0.74rem;
    color: #718096;
    text-align: center;
    margin: 0;
    font-style: italic;
  }
</style>
