---
import '../styles/design-system.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  noindex?: boolean;
}

const { title, description, canonicalUrl, noindex } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl ?? Astro.url.href} />
  {noindex && <meta name="robots" content="noindex, follow" />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl ?? Astro.url.href} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="impact-site-verification" content="de6421a5-42f2-4346-a159-965bc74e4747" />
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){window.dataLayer.push(arguments);}
    gtag('consent', 'default', {
      analytics_storage: 'denied',
      ad_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied'
    });
  </script>
</head>
<body>
  <nav class="site-nav">
    <div class="container nav-inner">
      <a class="nav-logo" href="/">
        <img src="/toolpolaris-logo-300.png" alt="ToolPolaris" width="36" height="36" />
        <span>Tool<span>Polaris</span></span>
      </a>
      <ul class="nav-links">
        <li><a href="/categories/">Browse by Role</a></li>
        <li><a href="/tools/">All Tools</a></li>
        <li><a href="/about/">About</a></li>
        <li><a href="/categories/" class="nav-cta">Find Your Stack &rarr;</a></li>
      </ul>
    </div>
  </nav>

  <slot />

  <footer class="site-footer">
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand">
          <a class="nav-logo" href="/">
            <img src="/toolpolaris-logo-300.png" alt="ToolPolaris" width="36" height="36" />
            <span>Tool<span>Polaris</span></span>
          </a>
          <p>Honest, role-specific AI tool rankings for marketing professionals.</p>
        </div>
        <div class="footer-col">
          <h4>Browse</h4>
          <ul>
            <li><a href="/categories/">Browse by Role</a></li>
            <li><a href="/tools/">All Tools</a></li>
            <li><a href="/tools/best-ai-writing-tools/">AI Writing</a></li>
            <li><a href="/tools/best-ai-seo-tools/">SEO &amp; Content</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <ul>
            <li><a href="/about/">About</a></li>
            <li><a href="/editorial-policy/">Editorial Policy</a></li>
            <li><a href="/contact/">Contact</a></li>
            <li><a href="/affiliate-disclosure/">Affiliate Disclosure</a></li>
            <li><a href="/privacy/">Privacy Policy</a></li>
            <li><a href="/terms/">Terms &amp; Refunds</a></li>
            <li><button class="cookie-button" type="button" data-cookie-preferences>Cookie Preferences</button></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 ToolPolaris. All rights reserved.</p>
        <p class="footer-disclosure">
          ToolPolaris participates in affiliate programs and may earn a commission when you purchase through links on this site. This does not influence our editorial rankings. See our <a href="/affiliate-disclosure/">affiliate disclosure</a> for full details.
        </p>
      </div>
    </div>
  </footer>

  <div class="cookie-notice" data-cookie-notice role="region" aria-label="Cookie notice">
    <div class="cookie-panel">
      <p>ToolPolaris uses optional analytics cookies to understand which pages help readers. You can accept analytics or decline non-essential cookies.</p>
      <div class="cookie-actions">
        <button class="cookie-accept" type="button" data-cookie-accept>Accept analytics</button>
        <button class="cookie-decline" type="button" data-cookie-decline>Decline</button>
      </div>
    </div>
  </div>

  <script>
    (() => {
      const consentKey = 'toolpolaris_cookie_consent';
      const notice = document.querySelector('[data-cookie-notice]');
      const acceptButton = document.querySelector('[data-cookie-accept]');
      const declineButton = document.querySelector('[data-cookie-decline]');
      const preferencesButton = document.querySelector('[data-cookie-preferences]');
      let analyticsLoaded = false;

      const loadAnalytics = () => {
        if (analyticsLoaded) return;
        analyticsLoaded = true;

        gtag('consent', 'update', {
          analytics_storage: 'granted'
        });

        const gaScript = document.createElement('script');
        gaScript.async = true;
        gaScript.src = 'https://www.googletagmanager.com/gtag/js?id=G-066V9FSHB8';
        document.head.appendChild(gaScript);

        gtag('js', new Date());
        gtag('config', 'G-066V9FSHB8');

        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src='https://www.clarity.ms/tag/'+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, 'clarity', 'script', 'x6xeu2ykmx');
      };

      const setConsent = (value) => {
        window.localStorage.setItem(consentKey, value);
        notice?.classList.remove('is-visible');
        if (value === 'accepted') {
          loadAnalytics();
        }
      };

      acceptButton?.addEventListener('click', () => setConsent('accepted'));
      declineButton?.addEventListener('click', () => setConsent('declined'));
      preferencesButton?.addEventListener('click', () => notice?.classList.add('is-visible'));

      const savedConsent = window.localStorage.getItem(consentKey);
      if (savedConsent === 'accepted') {
        loadAnalytics();
      } else if (!savedConsent) {
        notice?.classList.add('is-visible');
      }
    })();
  </script>
</body>
</html>
